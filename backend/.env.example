PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
COOKIE_SECRET=another-secret-key
NODE_ENV=development

# Email (Nodemailer - Gmail App Password)
# Hướng dẫn: myaccount.google.com/security → Mật khẩu ứng dụng
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=Thư viện Sơn Nhai <your@gmail.com>
ADMIN_EMAIL=your@gmail.com

# ── Chuyển khoản ngân hàng (VietQR + Casso) ──────────────────────────────────
# BIN ngân hàng: Techcombank=970407, VCB=970436, MBBank=970422, Agribank=970405
BANK_BIN=970407
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_NAME=NGUYEN VAN A

# Casso (casso.vn) — để tự động nhận webhook khi có tiền vào
# Nếu không có CASSO_API_KEY, dùng polling hoặc admin xác nhận thủ công
CASSO_API_KEY=AK_xxxxxxxxxxxxxxxx
CASSO_WEBHOOK_SECRET=your-webhook-secret

# ── SeaPay (seapay.vn) ─────────────────────────────────────────────────────────
# Đăng ký merchant tại: https://seapay.vn
# Sau khi đăng ký sẽ nhận được merchant_id và secret_key từ dashboard
SEAPAY_MERCHANT_ID=your_merchant_id
SEAPAY_SECRET_KEY=your_secret_key
# API URL (mặc định production, đổi thành sandbox nếu cần test)
# SEAPAY_API_URL=https://sandbox.payment.seapay.vn/api/v1/create_url

# Payment (simulate - không cần thật)
STRIPE_SECRET_KEY=sk_test_placeholder
VNPAY_TMN_CODE=placeholder
VNPAY_HASH_SECRET=placeholder

# App
APP_URL=http://localhost:3000
APP_NAME=Thư viện Sơn Nhai
DOWNLOAD_EXPIRE_DAYS=30
DOWNLOAD_MAX_COUNT=5
